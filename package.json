{
  "name": "learn-playwright-saucedemo-yarn",
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "test": "yarn playwright test",
    "test:chromium": "yarn playwright test --project=chromium",
    "test:headedWithChromium": "cross-env HEADED=true yarn playwright test --project=chromium",
    "test:firefox": "yarn playwright test --project=firefox",
    "test:webkit": "yarn playwright test --project=webkit",
    "test:allBrowsers": "yarn playwright test --project=chromium --project=firefox --project=webkit",
    "test:ci": "cross-env CI=true yarn playwright test",
    "test:salesforce": "yarn playwright test --project=sf_chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2"
  }
}